# ── SERVER ───────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8002
DEBUG=False

# ── CORS ─────────────────────────────────────────────────────────────────────
# Daftarkan semua origin yang boleh akses API (pisah koma, tanpa spasi).
# Isi dengan IP publik atau domain VPS kamu.
# Contoh: http://123.45.67.89:3000,https://app.yourdomain.com
CORS_ORIGINS=http://YOUR_VPS_IP:3000

# ── SCRAPER ──────────────────────────────────────────────────────────────────
# Di VPS tidak ada display, HARUS True.
TWITTER_HEADLESS=True
TWITTER_PROXY=
TWITTER_DELAY_BETWEEN_PROFILES=12
TWITTER_MIN_GAP_SECONDS=10
