# ══════════════════════════════════════════════════════════════════════════════
#  ROOT .env — dibaca oleh docker-compose.yml
#  Salin file ini jadi .env lalu isi sesuai VPS kamu:
#    cp .env.example .env
# ══════════════════════════════════════════════════════════════════════════════

# ── PORT MAPPING ─────────────────────────────────────────────────────────────
# Port yang di-expose di host (VPS). Ubah jika port sudah dipakai.
FRONTEND_PORT=3000
API_PORT=8002

# ── FRONTEND BUILD ARG ────────────────────────────────────────────────────────
# URL backend yang bisa diakses oleh BROWSER pengguna (bukan internal Docker).
# Isi dengan IP publik atau domain VPS kamu.
# Contoh:  http://123.45.67.89:8002
#          https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://YOUR_VPS_IP:8002
