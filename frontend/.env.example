# URL backend FastAPI yang bisa diakses oleh browser pengguna.
# Di Docker / VPS: isi dengan IP publik atau domain, bukan localhost.
# Contoh: http://123.45.67.89:8002  atau  https://api.yourdomain.com
# Catatan: variabel ini DI-BAKE saat `docker-compose up --build`, bukan runtime.
NEXT_PUBLIC_API_URL=http://YOUR_VPS_IP:8002
